# Audiobookshelf
# Base URL of your ABS instance (no trailing slash)
ABS_URL=http://audiobookshelf:13378
# API token from ABS → Settings → Users → your user → API Token
ABS_TOKEN=your_abs_api_token_here

# StoryGraph
STORYGRAPH_EMAIL=your-email@example.com
STORYGRAPH_PASSWORD=your-storygraph-password
